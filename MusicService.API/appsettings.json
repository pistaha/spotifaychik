{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Pagination": {
    "DefaultPageSize": 20,
    "MaxPageSize": 100
  },
  "Search": {
    "MaxResults": 50,
    "DefaultLimit": 10
  },
  "Database": {
    "ConnectionString": "Host=localhost;Port=5432;Database=music_service;Username=postgres;Password=postgres"
  },
  "JwtSettings": {
    "Issuer": "MusicService",
    "Audience": "MusicServiceClients",
    "Secret": "music-service-secret-key-32-chars-minimum-20260112",
    "AccessTokenExpirationMinutes": 30,
    "RefreshTokenExpirationDays": 7
  },
  "SecurityAudit": {
    "RetentionDays": 90,
    "CleanupIntervalHours": 24
  },
  "FileStorage": {
    "RootPath": "Storage",
    "MaxFileSizeBytes": 5368709120,
    "MaxTotalUploadBytes": 5368709120,
    "MaxFilesPerUpload": 10,
    "StreamingThresholdBytes": 10485760,
    "AllowAnyFile": true
  }
}
